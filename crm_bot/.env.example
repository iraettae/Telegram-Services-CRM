# Токен вашего бота (получите у @BotFather)
BOT_TOKEN=123456789:AaBbCcDdEeFfGg...

# ID мастер-группы, куда будут приходить сообщения.
# Убедитесь, что в группе включены "Темы" (Форум) и бот назначен администратором.
# ID группы обычно начинается с -100
MASTER_GROUP_ID=-1001234567890

# (Рекомендуется) Список операторов через запятую (ID или @username).
# ВАЖНО: при пустом списке операторов доступ к CRM закрыт (fail-closed).
OPERATORS=123456789,@your_username

# SOCKS5-прокси для обхода блокировки Telegram API
# Docker: socks5://warp:1080  |  Systemd+WARP: socks5://127.0.0.1:40000
PROXY_URL=socks5://warp:1080

# Публичный домен CRM (без https:// и без слэша). Отсюда собираются
# WEBHOOK_URL и WEBAPP_URL — больше не нужно править хардкод в коде.
PUBLIC_DOMAIN=crmsystem.yourdomain.com

# (Опционально) Явный URL WebApp для кнопки "Открыть CRM" (по умолчанию из PUBLIC_DOMAIN)
# WEBAPP_URL=https://crmsystem.yourdomain.com/

# (Опционально) Секрет для валидации Telegram webhook. Если пусто — выводится
# детерминированно из BOT_TOKEN. Задайте свой, если хотите ротацию независимо от токена.
# WEBHOOK_SECRET=

# (Опционально) TTL валидности Telegram initData в секундах (по умолчанию 86400 = 24ч)
# INIT_DATA_TTL=86400

# (Опционально) Путь к файлу БД (по умолчанию crm_data.db)
# DB_PATH=crm_data.db

# ─────────────────────────────────────────────────────────────────────────────
# Разовый импорт диалогов (import_dialogs.py). Нужен только когда доливаешь
# в CRM историю переписки из готовой Pyrogram-сессии; боту в проде не нужен.
# Без любой из этих переменных скрипт откажется стартовать, а не полезет
# в боевую БД с пустыми значениями.
#
# Приложение с https://my.telegram.org — то же, что у Комбайнера.
# USERBOT_API_ID=
# USERBOT_API_HASH=
# Имя .session-файла БЕЗ расширения (обычно это номер телефона аккаунта —
# поэтому в код его не вписываем).
# USERBOT_SESSION=
# Папка, где лежит этот .session (сессии живут у Комбайнера).
# USERBOT_SESSIONS_DIR=../tg_combiner/sessions
# JSON {telegram_user_id: business_connection_id} — к какому Business-подключению
# привязывать импортированные чаты. Сам id выдаёт Telegram при подключении бота
# к аккаунту, он равносилен доступу к переписке, так что держим его тут.
# USERBOT_BC_IDS={"123456789":"AAAAAAAAAAAAAAAAAAAAAAAAAA"}

# (Опционально) Вебхук авто-выгрузки готовых лидов. Когда AI ставит [LEAD_READY],
# CRM делает POST с данными лида (chat_id, phone, name, dob, citizenship, transport)
# на этот URL — Google Apps Script / Bitrix / API службы доставки. Пусто = выгрузка выключена.
# LEAD_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# (Опционально) Follow-up молчащим лидам. Если последнее сообщение — наше и лид
# молчит дольше FOLLOWUP_HOURS, AI шлёт мягкую реактивацию (не более FOLLOWUP_MAX раз).
# FOLLOWUP_HOURS=0 полностью выключает функцию.
# FOLLOWUP_HOURS=24
# FOLLOWUP_MAX=2
# FOLLOWUP_CHECK_MINUTES=30

# ─────────────────────────────────────────────────────────────────────────────
# AI-провайдеры (LLM-шлюзы). Бот идёт по фоллбек-цепочке: если модель/шлюз лёг,
# автоматически пробует следующий. Ключи храните ТОЛЬКО здесь (.env в .gitignore),
# не в коде. Основной ключ OnlySQ можно задать и в WebApp «Настройки ИИ» (поле
# api_key приоритетнее ENV). base_url'ы зашиты в коде (OnlySQ без /v1).
#
# Основной ключ OnlySQ. Если пусто и в БД пусто — используется фоллбек "free".
# Его же читают вспомогательные скрипты (test_prompt.py, ai_stress_test.py) —
# в них ключ больше не зашит.
# ONLYSQ_API_KEY=sq-xxxxxxxx
# Второй ключ OnlySQ — обход per-key лимита ~40 rpm (второе звено цепочки).
# ONLYSQ_API_KEY_ALT=sq-yyyyyyyy
# Ключ TokenLayer (Claude Opus). ВНИМАНИЕ: ротируется — при 401/403 обновите.
# TOKENLAYER_API_KEY=sk-xxxxxxxx
# Ключ sh00t.host (резервный Claude Opus). Лимит ≤4 параллельных запроса/ключ.
# SH00T_API_KEY=sk_xxxxxxxx
#
# Порядок фоллбек-цепочки "provider:model,...". По умолчанию (если пусто):
# onlysq:deepseek-v4-pro,onlysq_alt:deepseek-v4-pro,onlysq:deepseek-v4-flash,tokenlayer:claude-opus-4-8,sh00t:claude-opus-4-8
# Провайдеры: onlysq, onlysq_alt, tokenlayer, sh00t.  ⚠️ deepseek-v3/r1 мертвы — берите v4.
# AI_MODEL_CHAIN=onlysq:deepseek-v4-pro,onlysq_alt:deepseek-v4-pro,onlysq:deepseek-v4-flash,tokenlayer:claude-opus-4-8,sh00t:claude-opus-4-8
#
# Таймаут одного запроса к модели (сек) и общий бюджет на обход всей цепочки (сек).
# AI_REQUEST_TIMEOUT=45
# AI_TOTAL_DEADLINE=90
# Сколько держать «мёртвую» модель в чёрном списке до повторной попытки (сек).
# AI_DEAD_COOLDOWN=300
# AI_BUSY_COOLDOWN=30
