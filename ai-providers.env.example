# ══════════════════════════════════════════════════════════════════════════
# ai-providers.env.example — ШАБЛОН единой AI-конфигурации для ОБОИХ ботов.
# Скопируй в ai-providers.env и впиши ключи. Реальный файл в .gitignore.
#
#   cp ai-providers.env.example ai-providers.env
#
# Подключается crm-bot и tg-combiner через env_file в docker-compose.yml.
# Меняешь тут — меняется у обоих ботов (одна точка правды на цепочку).
# ══════════════════════════════════════════════════════════════════════════

# ── Ключи провайдеров-фоллбеков (живут ТОЛЬКО здесь) ───────────────────────
TOKENLAYER_API_KEY=sk-xxxxxxxx
SH00T_API_KEY=sk_xxxxxxxx

# ── OnlySQ (основной провайдер) ────────────────────────────────────────────
# Основной onlysq-ключ у каждого бота в своём месте (CRM — БД, Комбайнер — меню).
# Эти поля — общий fallback, если там не задано. Можно оставить пустыми.
ONLYSQ_API_KEY=
ONLYSQ_API_KEY_ALT=

# ── Порядок цепочки (единый для обоих ботов) ───────────────────────────────
AI_MODEL_CHAIN=onlysq:deepseek-v4-pro,onlysq_alt:deepseek-v4-pro,onlysq:deepseek-v4-flash,tokenlayer:claude-opus-4-8,sh00t:claude-opus-4-8

# ── Тайминги (сек) ─────────────────────────────────────────────────────────
AI_REQUEST_TIMEOUT=45
AI_TOTAL_DEADLINE=90
AI_DEAD_COOLDOWN=300
AI_BUSY_COOLDOWN=30
