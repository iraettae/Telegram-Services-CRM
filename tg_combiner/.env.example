# ── Обязательное ───────────────────────────────────────────────────────
# Без любого из четырёх бот НЕ СТАРТУЕТ (config.py падает с внятной ошибкой,
# а не молча виснет, как раньше).

# Telegram API credentials (https://my.telegram.org)
API_ID=
API_HASH=

# Bot token (@BotFather)
BOT_TOKEN=

# Твой числовой Telegram user id (@userinfobot).
# ВАЖНО: пустое значение больше НЕ означает «первый написавший станет админом» —
# раньше так и было, и бота мог перехватить любой, кто его нашёл.
ADMIN_ID=

# ── Сеть ───────────────────────────────────────────────────────────────
# ПУСТО = прямое подключение. Наш VPS во Франкфурте, Telegram доступен напрямую,
# поэтому оставляем пустыми. Заполнять только там, где Telegram блокируют:
#   Docker+WARP:   SOCKS5_HOST=warp        SOCKS5_PORT=1080
#   systemd+WARP:  SOCKS5_HOST=127.0.0.1   SOCKS5_PORT=40000
SOCKS5_HOST=
SOCKS5_PORT=

# ── WebApp ─────────────────────────────────────────────────────────────
# Базовый URL БЕЗ /app, например https://combiner.example.org
# Пусто = кнопки вебаппа не показываем вовсе (Telegram требует HTTPS-домен,
# голый IP и http:// он не примет).
WEBAPP_URL=
# Слушать только loopback; наружу — через nginx+TLS.
WEBAPP_BIND=127.0.0.1
WEBAPP_PORT=8080

# ── AI-парсер ──────────────────────────────────────────────────────────
# Ключ OnlySQ по умолчанию для меню парсера и разведчика чатов.
# Раньше он был ЗАХАРДКОЖЕН в исходниках и утёк в публичный репозиторий.
ONLYSQ_API_KEY=
# Остальная цепочка провайдеров и тайминги — в общем ai-providers.env
# (ONLYSQ_API_KEY_ALT, TOKENLAYER_API_KEY, SH00T_API_KEY, AI_MODEL_CHAIN,
#  AI_REQUEST_TIMEOUT, AI_TOTAL_DEADLINE, AI_DEAD_COOLDOWN, AI_BUSY_COOLDOWN).

# ── Связка с CRM ───────────────────────────────────────────────────────
# Куда Комбайнер стучится, записывая отправленный опенер в CRM.
# Нативный деплой: 127.0.0.1:8000 (в docker было бы crm-bot:8000).
CRM_API_URL=http://127.0.0.1:8000
# Общий секрет, должен совпадать с OUTREACH_SECRET у CRM.
OUTREACH_SECRET=

# ── Розыгрыши (опционально) ────────────────────────────────────────────
# Отдельное приложение my.telegram.org для аккаунтов розыгрышей.
# Без них кнопка «Добавить акк» честно скажет, что логин отключён.
GIVEAWAY_API_ID=
GIVEAWAY_API_HASH=
# Папка проекта розыгрышей. Если её нет — пульт остаётся неактивным.
# GIVEAWAY_DIR=/home/user1/tg_giveaways

# ── Антибан ────────────────────────────────────────────────────────────
# Суточный лимит отправок на аккаунт (переживает рестарт)
DAILY_ACCOUNT_LIMIT=40
# Базовый карантин аккаунта после спамблока, сек (растёт при повторах)
QUARANTINE_BASE_SECONDS=86400
