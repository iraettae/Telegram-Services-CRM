# Telegram API credentials (from https://my.telegram.org)
API_ID=
API_HASH=

# Bot token (from @BotFather)
BOT_TOKEN=

# Your Telegram user ID (the admin who controls the bot)
ADMIN_ID=

# SOCKS5 proxy for Telegram connectivity (Cloudflare WARP)
# Docker: host=warp, port=1080
# Systemd+WARP: host=127.0.0.1, port=40000
SOCKS5_HOST=warp
SOCKS5_PORT=1080

# WebApp base URL (your domain pointing to this service)
WEBAPP_URL=https://combiner.yourdomain.com/app

# (Optional) Gemini API key for AI reply generation in WebApp
# GEMINI_API_KEY=

# (Optional) Anti-ban: суточный лимит отправок на аккаунт (переживает рестарт)
# DAILY_ACCOUNT_LIMIT=40
# Базовый карантин аккаунта после спамблока в секундах (растёт при повторах)
# QUARANTINE_BASE_SECONDS=86400
