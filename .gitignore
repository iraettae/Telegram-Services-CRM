# Databases
*.sqlite3
*.db
crm_bot/crm_data.db

# Telegram-сессии: файл .session — это готовый доступ к аккаунту без пароля и 2FA.
*.session
*.session-journal

# Media and User Data
crm_bot/frontend/avatars/*
!crm_bot/frontend/avatars/.gitkeep
crm_bot/frontend/media/*
!crm_bot/frontend/media/.gitkeep
tg_combiner/sessions/*
!tg_combiner/sessions/.gitkeep
tg_combiner/webapp/static/avatars/*
!tg_combiner/webapp/static/avatars/.gitkeep

# Logs
logs/
*.log

# Backups (создаются backup-сервисом в docker-compose)
backups/

# Sensitive info
# Прокси-листы идут с логином/паролем, поэтому по имени, а не по пути.
proxies.json
tg_combiner/proxies.json
